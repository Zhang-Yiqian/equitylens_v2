# OpenRouter API Key (LLM routing)
# Register at: https://openrouter.ai/ → Settings → Keys → Create Key
# Preload $5 for testing (Gemini 2.5 Pro ~$0.02-0.08 per analysis)
OPENROUTER_API_KEY=sk-or-your_key_here

# SEC EDGAR User-Agent (required, free, no API key needed)
# Format: "YourName your@email.com"
SEC_EDGAR_USER_AGENT=YourName your@email.com

# macOS TLS fix: Path to system CA bundle (required on macOS for HTTPS calls)
# Node.js v23 global fetch fails without this: "unable to get local issuer certificate"
# On macOS this is /etc/ssl/cert.pem. On Linux usually /etc/ssl/certs/ca-certificates.crt
NODE_EXTRA_CA_CERTS=/etc/ssl/cert.pem
